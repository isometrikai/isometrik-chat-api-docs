  "info": {
    "version": "1.0",
    "title": "BroadcastForwardWeb"
  },
  "definitions": {
    "forward_message": {
      "type": "object",
      "title": "Response of forward message request",
      "required": [
        "msg"
      ],
      "properties": {
        "msg": {
          "type": "string",
          "description": "Message of successfull message forward."
        }
      },
      "example": {
        "msg": "Message forwarded successfully."
      },
      "description": "Successfully forwarded message."
    },
    "broadcast_message": {
      "type": "object",
      "title": "Response of broadcast message request",
      "required": [
        "msg"
      ],
      "properties": {
        "msg": {
          "type": "string",
          "description": "Message of successfull message broadcast."
        }
      },
      "example": {
        "msg": "Message broadcasted successfully."
      },
      "description": "Successfully broadcasted message."
    },
    "body_forward_message": {
      "type": "object",
      "title": "Body of the forward message request",
      "required": [
        "encrypted",
        "showInConversation",
        "body",
        "messageType"
      ],
      "properties": {
        "userIds": {
          "type": "array",
          "description": "List of user to forward message to(Can't be used with conversationIds param)."
        },
        "showInConversation": {
          "type": "boolean",
          "description": "Whether the message needs to be show in conversation."
        },
        "searchableTags": {
          "type": "array",
          "description": "List containing tags by which message can be searched(Maximum 20)."
        },
        "notificationTitle": {
          "type": "string",
          "description": "User defined notification title, if any."
        },
        "notificationBody": {
          "type": "string",
          "description": "User defined notification body, if any."
        },
        "metaData": {
          "type": "object",
          "description": "Object containing metadata of the message, if any."
        },
        "messageType": {
          "type": "integer",
          "description": "Type of message-allowed values are 0(normal)/1(forwarded)."
        },
        "events": {
          "$ref": "#/definitions/Events"
        },
        "encrypted": {
          "type": "boolean",
          "description": "Whether the message is encrypted."
        },
        "customType": {
          "type": "string",
          "description": "Custom message type, if any."
        },
        "conversationIds": {
          "type": "array",
          "description": "List of conversations to forward message to(Can't be used with userIds param)."
        },
        "body": {
          "type": "string",
          "description": "Body of the message sent."
        },
        "attachments": {
          "$ref": "#/definitions/Attachments"
        }
      },
      "example": {
        "userIds": [
          "5fb3daec21a38e73938a8d5b",
          "5fb4feb921a38e7b81fac663"
        ],
        "showInConversation": true,
        "searchableTags": [
          "public"
        ],
        "notificationTitle": "Notification Title",
        "notificationBody": "Notification body",
        "metaData": {
          "secretMessage": true
        },
        "messageType": 0,
        "events": {
          "updateUnreadCount": false,
          "sendPushNotification": true
        },
        "encrypted": true,
        "customType": "SelfDestruct",
        "conversationIds": [
          "6017d0da21a38e3440b3cb9c"
        ],
        "body": "message body",
        "attachments": [
          {
            "thumbnailUrl": "https://sample-file-url/media/1576213941566-unnamed-thumbnail.png",
            "size": 95860,
            "name": "unnamed.jpg",
            "mimeType": "image/jpeg",
            "mediaUrl": "https://sample-file-url/1576213941566-unnamed.jpg",
            "mediaId": "5df31dba3a22d30037d62066",
            "extension": "jpg",
            "attachmentType": 0
          }
        ]
      },
      "description": "Details of the forward message request."
    },
    "body_broadcast_message": {
      "type": "object",
      "title": "Body of the broadcast message request",
      "required": [
        "deviceId",
        "userIds",
        "encrypted",
        "showInConversation",
        "body",
        "messageType"
      ],
      "properties": {
        "userIds": {
          "type": "array",
          "description": "List of user to broadcast message to."
        },
        "showInConversation": {
          "type": "boolean",
          "description": "Whether the message needs to be show in conversation."
        },
        "searchableTags": {
          "type": "array",
          "description": "List containing tags by which message can be searched(Maximum 20)."
        },
        "notificationTitle": {
          "type": "string",
          "description": "User defined notification title, if any."
        },
        "notificationBody": {
          "type": "string",
          "description": "User defined notification body, if any."
        },
        "metaData": {
          "type": "object",
          "description": "Object containing metadata of the message, if any."
        },
        "messageType": {
          "type": "integer",
          "description": "Type of message-allowed values are 0(normal)/1(forwarded)."
        },
        "events": {
          "$ref": "#/definitions/Events"
        },
        "encrypted": {
          "type": "boolean",
          "description": "Whether the message is encrypted."
        },
        "deviceId": {
          "type": "string",
          "description": "Id of the device from which message was forwarded."
        },
        "customType": {
          "type": "string",
          "description": "Custom message type, if any."
        },
        "body": {
          "type": "string",
          "description": "Body of the message sent."
        },
        "attachments": {
          "$ref": "#/definitions/Attachments"
        }
      },
      "example": {
        "userIds": [
          "5fb3daec21a38e73938a8d5b",
          "5fb4feb921a38e7b81fac663"
        ],
        "showInConversation": true,
        "searchableTags": [
          "public"
        ],
        "notificationTitle": "Notification Title",
        "notificationBody": "Notification body",
        "metaData": {
          "secretMessage": true
        },
        "messageType": 0,
        "events": {
          "updateUnreadCount": false,
          "sendPushNotification": true
        },
        "encrypted": true,
        "deviceId": "ygd8zotW7",
        "customType": "SelfDestruct",
        "body": "message body",
        "attachments": [
          {
            "thumbnailUrl": "https://sample-file-url/media/1576213941566-unnamed-thumbnail.png",
            "size": 95860,
            "name": "unnamed.jpg",
            "mimeType": "image/jpeg",
            "mediaUrl": "https://sample-file-url/1576213941566-unnamed.jpg",
            "mediaId": "5df31dba3a22d30037d62066",
            "extension": "jpg",
            "attachmentType": 0
          }
        ]
      },
      "description": "Details of the broadcast message request."
    },
    "Events": {
      "type": "object",
      "title": "Message events details",
      "required": [
        "updateUnreadCount",
        "sendPushNotification"
      ],
      "properties": {
        "updateUnreadCount": {
          "type": "boolean",
          "description": "Whether to update unread messages count."
        },
        "sendPushNotification": {
          "type": "boolean",
          "description": "Whether to send push notification."
        }
      },
      "description": "Model containing details of the message events."
    },
    "Error_503": {
      "type": "object",
      "title": "Error_503",
      "required": [
        "error"
      ],
      "properties": {
        "error": {
          "type": "string",
          "description": "The message of the error raised."
        }
      },
      "description": "Service Unavailable."
    },
    "Error_422": {
      "type": "object",
      "title": "Error_422",
      "properties": {
        "error": {
          "type": "object",
          "required": [
            "error_key"
          ],
          "properties": {
            "error_key": {
              "type": "array",
              "example": [
                "The message of the first error raised.",
                "The message of the second error raised."
              ],
              "description": "Array containing list of error messages."
            }
          }
        }
      },
      "description": "Unprocessable entity."
    },
    "Error_404_forward_message": {
      "type": "object",
      "title": "Error_404_forward_message",
      "required": [
        "errorCode",
        "error"
      ],
      "properties": {
        "errorCode": {
          "type": "integer",
          "description": "0"
        },
        "error": {
          "type": "string",
          "description": "The message of the error raised."
        }
      },
      "description": "errorCode- 0 => licenseKey not found, 1 => Forward to users or sender not found or sender is blocked."
    },
    "Error_404_broadcast_message": {
      "type": "object",
      "title": "Error_404_broadcast_message",
      "required": [
        "errorCode",
        "error"
      ],
      "properties": {
        "errorCode": {
          "type": "integer",
          "description": "0"
        },
        "error": {
          "type": "string",
          "description": "The message of the error raised."
        }
      },
      "description": "errorCode- 0 => licenseKey not found, 1 => Broadcast to users or sender not found or sender is blocked."
    },
    "Error_403_forward_message": {
      "type": "object",
      "title": "Error_403_forward_message",
      "required": [
        "errorCode",
        "error"
      ],
      "properties": {
        "errorCode": {
          "type": "integer",
          "description": "0"
        },
        "error": {
          "type": "string",
          "description": "The message of the error raised."
        }
      },
      "description": "errorCode- 0 => Allowed messages limit exceeded, 1 => Allowed messages limit shall be exceeded, 2 => Allowed conversations limit shall be exceeded, 3 => Sender is blocked, 4 => Sender not found, 11 => Account not verified yet, 12 => Account has been suspended, 13 => Invalid account status, 14 => Billing subscription not added, 15 => Billing subscription expired or not renewed or canceled, 16 => Invalid project status, 17 => Billing subscription expired."
    },
    "Error_403_broadcast_message": {
      "type": "object",
      "title": "Error_403_broadcast_message",
      "required": [
        "errorCode",
        "error"
      ],
      "properties": {
        "errorCode": {
          "type": "integer",
          "description": "0"
        },
        "error": {
          "type": "string",
          "description": "The message of the error raised."
        }
      },
      "description": "errorCode- 0 => Allowed messages limit exceeded, 1 => Allowed messages limit shall be exceeded, 2 => Allowed conversations limit shall be exceeded, 3 => Sender is blocked, 11 => Account not verified yet, 12 => Account has been suspended, 13 => Invalid account status, 14 => Billing subscription not added, 15 => Billing subscription expired or not renewed or canceled, 16 => Invalid project status, 17 => Billing subscription expired."
    },
    "Error_400_forward_message": {
      "type": "object",
      "title": "Error_400_forward_message",
      "required": [
        "error"
      ],
      "properties": {
        "error": {
          "type": "string",
          "description": "The message of the error raised."
        }
      },
      "description": "Conversations not found or not allowed to forward message."
    },
    "Attachments": {
      "type": "array",
      "title": "Message attachments",
      "items": {
        "$ref": "#/definitions/Attachment"
      },
      "description": "All attachments for a message."
    },
    "Attachment": {
      "type": "object",
      "title": "Attachment details",
      "required": [
        "thumbnailUrl",
        "size",
        "attachmentType",
        "extension",
        "mimeType",
        "name",
        "mediaUrl",
        "mediaId"
      ],
      "properties": {
        "thumbnailUrl": {
          "type": "string",
          "description": "Thumbnail url of the media attachment, if any."
        },
        "size": {
          "type": "integer",
          "description": "Size of the media in bytes"
        },
        "name": {
          "type": "string",
          "description": "Name of the media(with extension appended)."
        },
        "mimeType": {
          "type": "string",
          "description": "Mime type of the media."
        },
        "mediaUrl": {
          "type": "string",
          "description": "Url of the media attachment."
        },
        "mediaId": {
          "type": "string",
          "description": "Unique identifier of the attachment media."
        },
        "extension": {
          "type": "boolean",
          "description": "Whether user is online now."
        },
        "attachmentType": {
          "type": "integer",
          "description": "Media attachment type.Supported value 0-8, where 8 is for custom type and is not added in default UI of sdk."
        }
      },
      "description": "Model containing details of the attachment."
    }
  }
}
